{
    "name": "janchris80/laravel-drive-files",
    "description": "Google Drive file management for Laravel — personal Google account (OAuth 2.0), resumable uploads, sharing, metadata storage, and optional permission gating.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "google-drive", "files", "uploads", "resumable", "sharing", "oauth"],
    "authors": [
        {
            "name": "Jungie Canghagas",
            "email": "janchris80@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "google/apiclient": "^2.17",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "spatie/laravel-activitylog": "Enables audit trail on DriveFile model (^4.12)",
        "spatie/laravel-permission": "Enables role/permission gating via the DrivePermission middleware (^6.0)"
    },
    "autoload": {
        "psr-4": {
            "Janchris80\\DriveFiles\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Janchris80\\DriveFiles\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Janchris80\\DriveFiles\\DriveFilesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
